        [],
    )
    .context("days テーブルの作成に失敗しました")?;
    conn.execute(
        "CREATE TABLE IF NOT EXISTS notes (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            owner_type  TEXT NOT NULL,
            owner_id    INTEGER NOT NULL,
            title       TEXT,
            body        TEXT NOT NULL,
