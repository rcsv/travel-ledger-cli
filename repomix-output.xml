fn normalize_export_md_timestamp(markdown: &str) -> String {
    markdown
        .lines()
        .map(|line| {
            if line.starts_with("Generated at: ") {
                "Generated at: TIMESTAMP"
            } else {
                line
            }
        })
        .collect::<Vec<_>>()
        .join("\n")
}

