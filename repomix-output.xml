    conn.execute(
        "CREATE TABLE IF NOT EXISTS expenses (
            id              INTEGER PRIMARY KEY AUTOINCREMENT,
            itinerary_id    INTEGER NOT NULL,
            title           TEXT,
            amount          INTEGER NOT NULL,
            currency        TEXT NOT NULL,
