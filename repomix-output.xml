    conn.execute(
        "CREATE TABLE IF NOT EXISTS days (
            id          INTEGER PRIMARY KEY AUTOINCREMENT,
            trip_id     INTEGER NOT NULL,
            day_number  INTEGER NOT NULL,
            title       TEXT NOT NULL DEFAULT '',
            summary     TEXT,
