EOF
}

if [ "$#" -ge 2 ]; then
  export VNUM="$(with_v "$1")"
  shift
  export VSTR="$*"
elif [ -n "${VNUM:-}" ] && [ -n "${VSTR:-}" ]; then
  export VNUM="$(with_v "$VNUM")"
  export VSTR
else
