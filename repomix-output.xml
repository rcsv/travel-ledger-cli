        .flat_map(|(itinerary_key, expenses)| {
            expenses.iter().cloned().map(move |expense| ExportExpense {
                itinerary_key: itinerary_key.clone(),
                expense,
            })
        })
        .collect()
}

pub(crate) fn flatten_reservations_from_v3(export: &TripExportV3) -> Vec<ExportReservation> {
    export
