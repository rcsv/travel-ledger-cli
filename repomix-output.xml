            None,
            None,
            None,
            None,
        )
        .unwrap();

        let expected = vec![
            "Late time early order".to_string(),
            "Middle no time".to_string(),
            "Early time late order".to_string(),
        ];

        let list_titles: Vec<_> = crate::itinerary::list_itinerary_items(&conn, trip_id)
            .unwrap()
            .into_iter()
            .map(|i| i.title)
